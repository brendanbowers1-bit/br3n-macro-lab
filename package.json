{
  "name": "bowers-frontier-macro-labs",
  "version": "1.0.0",
  "private": true,
  "description": "Bowers Frontier Macro Labs — USD/MXN corridor intelligence research system",
  "scripts": {
    "install:all": "npm install --prefix web_dashboard && npm install --prefix model-lab",
    "build": "npm run build --prefix web_dashboard",
    "build:pages": "npm run build:pages --prefix web_dashboard",
    "data:build:usd-mxn": "node scripts/build_usd_mxn_sample_dataset.js",
    "data:validate:usd-mxn": "node scripts/validate_usd_mxn_dataset.js",
    "model:run:usd-mxn": "node scripts/run_usd_mxn_models.js",
    "model:smoke": "node model-lab/scripts/smoke_test.js",
    "model:pull": "bash model-lab/scripts/pull_local_models.sh",
    "model:ingest": "node model-lab/scripts/ingest_documents.js",
    "brief:usd-mxn": "node model-lab/scripts/run_corridor_brief.js",
    "model:eval": "node model-lab/scripts/run_evals.js",
    "system:run": "node scripts/run_bowers_frontier_pipeline.js",
    "corridor:run": "python3 scripts/run_corridor_intelligence.py",
    "lake:ingest": "python3 scripts/ingest_fred_policy_rate.py && python3 scripts/ingest_banxico_fx.py && python3 scripts/ingest_banxico_policy_rate.py && python3 scripts/ingest_rpw_remittance_cost.py",
    "lake:ingest:fx": "python3 scripts/ingest_banxico_fx.py",
    "lake:ingest:mx-rate": "python3 scripts/ingest_banxico_policy_rate.py",
    "lake:ingest:rpw": "python3 scripts/ingest_rpw_remittance_cost.py",
    "lake:validate": "python3 scripts/validate_data_lake.py",
    "lake:build": "python3 scripts/build_usd_mxn_canonical.py",
    "lake:run": "python3 scripts/run_data_lake_pipeline.py",
    "model:brief": "npm run brief:usd-mxn",
    "model:brief:py": "npm run model:brief --prefix model-lab",
    "model:test": "npm run model:test --prefix model-lab",
    "export:dashboard": "python3 scripts/export_dashboard_api.py"
  }
}
